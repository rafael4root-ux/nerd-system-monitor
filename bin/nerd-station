#!/bin/bash
# ═══════════════════════════════════════════════
# NERD STATION - Unified Control Panel
# ═══════════════════════════════════════════════
# Launch with: Ctrl+Alt+N or nerd-station
# ═══════════════════════════════════════════════

THEME="$HOME/.config/rofi/nerd-theme.rasi"
SCRIPTS_DIR="$HOME/.local/bin"

# Quick system stats for header
CPU=$(grep -o '[0-9]*\.[0-9]*' /proc/loadavg | head -1)
MEM=$(free -h | awk 'NR==2 {printf "%s/%s", $3, $2}')
DOCKER_COUNT=$(docker ps -q 2>/dev/null | wc -l)
SERVICES_RUNNING=$(systemctl list-units --type=service --state=running --no-legend 2>/dev/null | wc -l)

SELECTED=$(echo -e "\
━━━ GERENCIAMENTO ━━━━━━━━━━━━━━━━━━━━━
⚡ Process Manager        Kill/signal processes
🐳 Docker Manager         Start/stop/restart containers  
⚙  Service Manager        Systemd services on/off
━━━ ABRIR ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🖥  btop                   Interactive system monitor
📊 glances                 Web dashboard monitor
📋 nmon                    Compact system monitor
🗂  Gerenciador de Arquivos
🔧 Configurações do Sistema
💻 Terminal
━━━ REDE ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
🌐 Network Ports           Show listening ports
🔌 Active Connections       Show established connections
📡 WiFi Networks           Scan WiFi networks
━━━ SISTEMA ━━━━━━━━━━━━━━━━━━━━━━━━━━━
🧹 System Cleanup          APT clean + logs clean
🔋 Battery Info            Detailed battery status
🌡  Sensors                 Temperature sensors
💾 Disk Usage              Largest directories
📦 Gerenciador de Pacotes  (APT)
🖥  Informações do Sistema
━━━ AJUDA ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
⌨  Atalhos do Teclado" | rofi -dmenu \
    -theme "$THEME" \
    -p "⚡ NERD STATION" \
    -mesg "CPU: $CPU | RAM: $MEM | Docker: $DOCKER_COUNT | Services: $SERVICES_RUNNING" \
    -i)

[[ -z "$SELECTED" ]] && exit 0

open_terminal() {
    if command -v gnome-terminal &>/dev/null; then
        gnome-terminal -- bash -c "$1; echo ''; echo 'Press Enter to close...'; read"
    elif command -v xterm &>/dev/null; then
        xterm -e "$1; read"
    fi
}

case "$SELECTED" in
    *"Process Manager"*)
        "$SCRIPTS_DIR/nerd-process-manager"
        ;;
    *"Docker Manager"*)
        "$SCRIPTS_DIR/nerd-docker-manager"
        ;;
    *"Service Manager"*)
        "$SCRIPTS_DIR/nerd-service-manager"
        ;;
    *"btop"*)
        open_terminal "btop"
        ;;
    *"glances"*)
        open_terminal "glances"
        ;;
    *"nmon"*)
        open_terminal "nmon"
        ;;
    *"Network Ports"*)
        PORTS=$(ss -tlnp 2>/dev/null | awk 'NR>1 {
            split($4,a,":"); port=a[length(a)]; 
            split($6,p,"\""); proc=p[2]; 
            if(proc=="") proc="???"; 
            printf "%-8s %-20s %s\n", port, proc, $4
        }' | sort -t' ' -k1 -n | uniq)
        echo "$PORTS" | rofi -dmenu \
            -theme "$THEME" \
            -p "🌐 PORTS" \
            -mesg "PORT     PROCESS              ADDRESS" \
            -i
        ;;
    *"Active Connections"*)
        CONNS=$(ss -tnp state established 2>/dev/null | awk 'NR>1 {
            split($4,l,":"); split($5,r,":"); 
            split($6,p,"\""); proc=p[2]; 
            if(proc=="") proc="???"; 
            printf "%-15s %-6s → %-20s %-6s\n", proc, l[length(l)], r[1], r[length(r)]
        }' | sort)
        COUNT=$(echo "$CONNS" | wc -l)
        echo "$CONNS" | rofi -dmenu \
            -theme "$THEME" \
            -p "🔌 CONNECTIONS" \
            -mesg "Established: $COUNT | PROCESS  LOCAL → REMOTE  PORT" \
            -i
        ;;
    *"WiFi"*)
        notify-send "📡 Scanning WiFi..." -t 2000
        WIFI=$(nmcli -t -f SSID,SIGNAL,SECURITY device wifi list 2>/dev/null | sort -t: -k2 -rn | awk -F: '{
            bars = int($2/20)
            signal = ""
            for(i=0;i<bars;i++) signal = signal "█"
            for(i=bars;i<5;i++) signal = signal "░"
            printf "%-25s %s %3s%% %s\n", $1, signal, $2, $3
        }')
        echo "$WIFI" | rofi -dmenu \
            -theme "$THEME" \
            -p "📡 WIFI" \
            -mesg "Available networks" \
            -i
        ;;
    *"System Cleanup"*)
        CONFIRM=$(echo -e "✓ YES - Run cleanup\n✗ NO - Cancel" | rofi -dmenu \
            -theme "$THEME" \
            -p "🧹 CLEANUP" \
            -mesg "APT autoremove + clean + journal vacuum")
        if [[ "$CONFIRM" == *"YES"* ]]; then
            pkexec bash -c "apt autoremove -y && apt clean && journalctl --vacuum-time=7d" 2>&1
            notify-send "🧹 System Cleanup" "Complete!" -t 3000
        fi
        ;;
    *"Battery"*)
        BAT_INFO=$(upower -i /org/freedesktop/UPower/devices/battery_BAT0 2>/dev/null)
        echo "$BAT_INFO" | rofi -dmenu \
            -theme "$THEME" \
            -p "🔋 BATTERY" \
            -mesg "Detailed battery information" \
            -i
        ;;
    *"Sensors"*)
        TEMPS=$(sensors 2>/dev/null)
        echo "$TEMPS" | rofi -dmenu \
            -theme "$THEME" \
            -p "🌡 SENSORS" \
            -mesg "Temperature sensors" \
            -i
        ;;
    *"Disk Usage"*)
        DISK=$(du -h --max-depth=1 "$HOME" 2>/dev/null | sort -rh | head -20)
        echo "$DISK" | rofi -dmenu \
            -theme "$THEME" \
            -p "💾 DISK" \
            -mesg "Largest directories in \$HOME" \
            -i
        ;;
    *"Gerenciador de Arquivos"*)
        if command -v nautilus &>/dev/null; then
            nautilus "$HOME" &
        elif command -v thunar &>/dev/null; then
            thunar "$HOME" &
        elif command -v nemo &>/dev/null; then
            nemo "$HOME" &
        elif command -v dolphin &>/dev/null; then
            dolphin "$HOME" &
        else
            notify-send "⚠ Nerd Station" "Nenhum gerenciador de arquivos encontrado" -t 3000
        fi
        ;;
    *"Configurações do Sistema"*)
        if command -v gnome-control-center &>/dev/null; then
            gnome-control-center &
        elif command -v xfce4-settings-manager &>/dev/null; then
            xfce4-settings-manager &
        elif command -v systemsettings5 &>/dev/null; then
            systemsettings5 &
        else
            notify-send "⚠ Nerd Station" "Nenhum painel de configurações encontrado" -t 3000
        fi
        ;;
    *"Terminal"*)
        if command -v gnome-terminal &>/dev/null; then
            gnome-terminal &
        elif command -v xfce4-terminal &>/dev/null; then
            xfce4-terminal &
        elif command -v konsole &>/dev/null; then
            konsole &
        elif command -v xterm &>/dev/null; then
            xterm &
        fi
        ;;
    *"Gerenciador de Pacotes"*)
        ACTIONS=$(echo -e "📋 Listar pacotes instalados\n🔄 Atualizar lista de pacotes\n⬆  Atualizar sistema (upgrade)\n🔍 Buscar pacote" | rofi -dmenu \
            -theme "$THEME" \
            -p "📦 APT" \
            -mesg "Gerenciador de Pacotes (APT)" \
            -i)
        case "$ACTIONS" in
            *"Listar"*)
                PKGS=$(dpkg --get-selections | grep -v deinstall | awk '{print $1}' | head -100)
                echo "$PKGS" | rofi -dmenu \
                    -theme "$THEME" \
                    -p "📋 PACOTES" \
                    -mesg "Pacotes instalados (top 100)" \
                    -i
                ;;
            *"Atualizar lista"*)
                pkexec apt update 2>&1
                notify-send "📦 APT" "Lista de pacotes atualizada" -t 3000
                ;;
            *"Atualizar sistema"*)
                CONFIRM=$(echo -e "✓ SIM - Atualizar\n✗ NÃO - Cancelar" | rofi -dmenu \
                    -theme "$THEME" \
                    -p "⚠ CONFIRMAR" \
                    -mesg "Executar apt upgrade?")
                if [[ "$CONFIRM" == *"SIM"* ]]; then
                    open_terminal "sudo apt upgrade -y"
                fi
                ;;
            *"Buscar"*)
                QUERY=$(echo "" | rofi -dmenu \
                    -theme "$THEME" \
                    -p "🔍 BUSCAR" \
                    -mesg "Digite o nome do pacote")
                if [[ -n "$QUERY" ]]; then
                    RESULTS=$(apt-cache search "$QUERY" 2>/dev/null | head -30)
                    echo "$RESULTS" | rofi -dmenu \
                        -theme "$THEME" \
                        -p "📦 RESULTADOS" \
                        -mesg "Pacotes encontrados para: $QUERY" \
                        -i
                fi
                ;;
        esac
        ;;
    *"Informações do Sistema"*)
        SYS_INFO=$(echo -e "\
Host:      $(hostname)
OS:        $(lsb_release -d 2>/dev/null | cut -f2 || cat /etc/os-release | grep PRETTY | cut -d'"' -f2)
Kernel:    $(uname -r)
Arch:      $(uname -m)
Uptime:    $(uptime -p)
CPU:       $(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)
Cores:     $(nproc)
RAM Total: $(free -h | awk '/Mem:/ {print \$2}')
RAM Usada: $(free -h | awk '/Mem:/ {print \$3}')
Swap:      $(free -h | awk '/Swap:/ {print \$3\"/\"\$2}')
Disco /:   $(df -h / | awk 'NR==2 {print \$3\"/\"\$2\" (\"\$5\")\"}')")
        echo "$SYS_INFO" | rofi -dmenu \
            -theme "$THEME" \
            -p "🖥 INFO" \
            -mesg "Informações do Sistema" \
            -i
        ;;
    *"Atalhos do Teclado"*)
        SHORTCUTS=$(echo -e "\
⌨  ATALHOS DO TECLADO
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Ctrl + Alt + N     ⚡ Nerd Station (este menu)
Ctrl + Alt + K     ⚡ Process Manager
Ctrl + Alt + D     🐳 Docker Manager
Ctrl + Alt + S     ⚙  Service Manager
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  DENTRO DO PROCESS MANAGER:
Alt + K            ☠ SIGKILL rápido
Alt + 9            ☠ SIGKILL rápido
Alt + F            ☠ Force kill (com filhos)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  GERAL:
Digite para filtrar opções no Rofi
Esc                Fechar / Voltar")
        echo "$SHORTCUTS" | rofi -dmenu \
            -theme "$THEME" \
            -p "⌨ ATALHOS" \
            -mesg "Atalhos de teclado do Nerd Station" \
            -i
        ;;
    *"━━━"*)
        # Ignore separator lines
        ;;
esac
